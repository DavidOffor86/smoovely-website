# ---------------------------------------------------------------------------
# Smoovely QuickMove — environment variables
# Copy this file to `.env.local` for local dev, and set the same keys in your
# host's dashboard (Vercel → Project → Settings → Environment Variables).
# `.env.local` is gitignored and must never be committed.
# ---------------------------------------------------------------------------

# --- Maintenance mode ------------------------------------------------------
# "true" shows the Under Construction page across the whole site.
MAINTENANCE_MODE=false
# Optional: take only specific routes offline (comma-separated), e.g. /quote,/careers
# Leave blank when MAINTENANCE_MODE handles the whole site.
MAINTENANCE_PATHS=

# --- Quote submission pipeline --------------------------------------------
# Power Automate (or any HTTP) webhook that receives each configurator submission.
# Create this in Power Automate: trigger "When an HTTP request is received".
POWER_AUTOMATE_WEBHOOK_URL=

# --- Optional direct email notification ------------------------------------
# Only needed if you want the API to ALSO email directly (in addition to / instead
# of Power Automate). Leave blank to rely on Power Automate for notifications.
RESEND_API_KEY=
NOTIFY_EMAIL=
